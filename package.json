{
  "name": "vscode-notebook-mcp",
  "displayName": "VS Code Notebook MCP",
  "description": "Expose open Jupyter notebooks in VS Code to MCP-compatible AI agents.",
  "version": "0.1.0",
  "publisher": "colmryan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/caryan/vscode-notebook-mcp.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Notebooks",
    "Data Science",
    "AI"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "notebook-mcp.restartServer",
        "title": "Notebook MCP: Restart Server"
      },
      {
        "command": "notebook-mcp.showInfo",
        "title": "Notebook MCP: Show Server Info"
      }
    ],
    "configuration": {
      "title": "Notebook MCP",
      "properties": {
        "notebook-mcp.port": {
          "type": "number",
          "default": 49777,
          "minimum": 1024,
          "maximum": 65535,
          "description": "Preferred port. If unavailable, the next free port (up to +99) is chosen automatically."
        }
      }
    },
    "viewsContainers": {
      "panel": [
        {
          "id": "notebook-mcp-utility",
          "title": "Notebook MCP",
          "icon": "$(notebook)"
        }
      ]
    },
    "views": {
      "notebook-mcp-utility": [
        {
          "type": "webview",
          "id": "notebook-mcp.plotlyRenderer",
          "name": "Plotly Renderer",
          "visibility": "collapsed"
        }
      ]
    }
  },
  "extensionDependencies": [
    "ms-toolsai.jupyter"
  ],
  "scripts": {
    "vscode:prepublish": "npm run build",
    "copy:plotly": "node -e \"require('fs').mkdirSync('dist',{recursive:true});require('fs').copyFileSync('node_modules/plotly.js-dist-min/plotly.min.js','dist/plotly.min.js')\"",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap && npm run copy:plotly",
    "watch": "npm run build -- --watch",
    "typecheck": "tsc --noEmit",
    "build:test": "tsc -p tsconfig.test.json",
    "test:setup-python": "bash scripts/setup-test-python.sh",
    "pretest": "npm run build && npm run build:test && npm run test:setup-python",
    "test": "node out/test/integration/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.4.1",
    "esbuild": "^0.20.0",
    "glob": "^10.4.5",
    "mocha": "^10.7.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "plotly.js-dist-min": "^3.5.0",
    "zod": "^3.23.8"
  }
}
